rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if request is from your GitHub Pages site
    function isFromGitHubPages() {
      return request.host.matches('logic06183\\.github\\.io');
    }

    // Helper function to check if request is from localhost (for development)
    function isLocalhost() {
      return request.host.matches('localhost') || request.host.matches('127\\.0\\.0\\.1');
    }

    // Helper function to check if access is allowed
    function isAllowed() {
      return isFromGitHubPages() || isLocalhost();
    }

    // Orders collection - restrict to your domain
    match /orders/{orderId} {
      allow read, write: if isAllowed();
    }

    // Archived orders collection - restrict to your domain
    match /archivedOrders/{orderId} {
      allow read, write: if isAllowed();
    }

    // System configuration - restrict to your domain
    match /systemConfig/{configId} {
      allow read, write: if isAllowed();
    }

    // Deny access to everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
