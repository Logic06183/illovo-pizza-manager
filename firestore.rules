rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Orders collection - Allow read/write access
    // Security note: For production, consider adding Firebase Authentication
    // and restricting to: allow read, write: if request.auth != null;
    match /orders/{orderId} {
      allow read, write: if true;
    }

    // Archived orders collection - Allow read/write access
    match /archivedOrders/{orderId} {
      allow read, write: if true;
    }

    // System configuration - Allow read/write access
    match /systemConfig/{configId} {
      allow read, write: if true;
    }

    // Deny access to everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
